#!/bin/bash
# Run Claude Code in Docker with mounted volumes and persistent auth
#
# Usage: ./dclaude -v <folder> [-v <folder> ...] [-- <claude args>]
#   Folders are relative to $HOME and mounted at /home/claude/<folder>
#   Example: ./dclaude -v cx -v ak -- --help

if [[ "$1" == "--help" || "$1" == "-h" ]]; then
  echo "Usage: ./dclaude -v <folder> [-p <port>] [-- <claude args>]"
  echo ""
  echo "  -v <folder>   Mount ~/folder to /home/claude/folder (repeatable)"
  echo "  -p <port>     Forward host port into the container (repeatable)"
  echo "  --            Separator; remaining args are passed to claude"
  echo "  -h, --help    Show this help"
  echo ""
  echo "Examples:"
  echo "  ./dclaude -v cx -v ak"
  echo "  ./dclaude -v cx -p 5432"
  echo "  ./dclaude -v cx -v ak -- --help"
  exit 0
fi

AUTH_ARGS=()
if [ -n "$ANTHROPIC_API_KEY" ]; then
  AUTH_ARGS+=(-e "ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY")
else
  # Try to extract OAuth credentials from macOS Keychain
  OAUTH_CREDS=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null)
  if [ -n "$OAUTH_CREDS" ]; then
    # Note: credentials are briefly visible via `docker inspect` but are
    # unset from the process environment in entrypoint.sh.
    AUTH_ARGS+=(-e "CLAUDE_OAUTH_CREDENTIALS=$OAUTH_CREDS")
  else
    echo "Error: ANTHROPIC_API_KEY is not set and no OAuth credentials found in Keychain" >&2
    exit 1
  fi
fi

VOLUME_ARGS=()
PORT_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -v)
      if [ -z "$2" ]; then
        echo "Error: -v requires a folder name" >&2
        exit 1
      fi
      VOLUME_ARGS+=(-v "$HOME/$2:/home/claude/$2")
      shift 2
      ;;
    -p)
      if [ -z "$2" ]; then
        echo "Error: -p requires a port number" >&2
        exit 1
      fi
      PORT_ARGS+=(-p "$2:$2")
      shift 2
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done

if [ ${#VOLUME_ARGS[@]} -eq 0 ]; then
  read -p "No folders mounted. Continue? [y/N] " answer
  if [[ ! "$answer" =~ ^[Yy]$ ]]; then
    exit 0
  fi
fi

# Persistent .claude.json for the Docker container
CLAUDE_JSON="$HOME/.claude-docker.json"
if [ ! -f "$CLAUDE_JSON" ]; then
  echo '{"hasCompletedOnboarding":true,"lastOnboardingVersion":"2.1.23"}' > "$CLAUDE_JSON"
fi

# Cargo registry is mounted for crate caching between runs.
# Cargo target dir is NOT mounted — it lives inside the container because
# Docker Desktop's VirtioFS file sharing is too slow for Rust's heavy I/O.
CARGO_REGISTRY="$HOME/.dclaude-cargo-registry"
mkdir -p "$CARGO_REGISTRY"

# Mount gcloud config if it exists
if [ -d "$HOME/.config/gcloud" ]; then
  VOLUME_ARGS+=(-v "$HOME/.config/gcloud:/home/claude/.config/gcloud")
fi

# Map current host directory to its container equivalent
CONTAINER_WD=$(echo "$PWD" | sed "s|$HOME/|/home/claude/|")

docker run -it --rm \
  --add-host=host.docker.internal:host-gateway \
  "${AUTH_ARGS[@]}" \
  "${VOLUME_ARGS[@]}" \
  "${PORT_ARGS[@]}" \
  -v "$CARGO_REGISTRY":/home/claude/.cargo/registry \
  -v "$HOME/.claude":/home/claude/.claude \
  -v "$HOME/.gitconfig":/home/claude/.gitconfig:ro \
  -v "$HOME/.ssh":/home/claude/.ssh:ro \
  -v "$CLAUDE_JSON":/home/claude/.claude.json \
  -w "$CONTAINER_WD" \
  akolov/claude "$@"
